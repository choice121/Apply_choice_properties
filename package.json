{
  "name": "apply-choice-properties",
  "version": "1.0.0",
  "private": true,
  "description": "Choice Properties — Rental Application Form. Static site deployed to Cloudflare Pages. Backend is Google Apps Script.",
  "scripts": {
    "start": "node server.js",
    "preview": "node server.js",
    "dev": "node server.js",
    "build": "node generate-config.js",
    "gas:login": "clasp login --no-localhost",
    "gas:push": "node scripts/gas-push.js",
    "gas:status": "clasp status",
    "gas:open": "clasp open",
    "gas:encrypt": "node scripts/gas-encrypt.js",
    "gas:setup": "node scripts/gas-setup.js",
    "gas:pull": "node scripts/gas-pull.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@google/clasp": "^2.5.0"
  }
}
